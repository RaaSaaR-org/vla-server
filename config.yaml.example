# VLA Server Configuration
#
# Copy to config.yaml and adjust for your setup:
#   cp config.yaml.example config.yaml

# Model backend: "smolvla", "pi05" (stub), or "groot" (GR00T N1.7 via ZMQ)
model: smolvla

# HuggingFace repo ID or local checkpoint path
model_path: lerobot/smolvla_base

# Device: "mps" (Mac), "cuda" (NVIDIA GPU), "cpu"
device: mps

# Server bind address and port
host: 0.0.0.0
port: 8000

# Service token — clients must send "Authorization: Bearer <token>".
# /health stays open for healthchecks. Leave empty ONLY for local dev.
# Generate one with: openssl rand -hex 32
# Env override: VLA_AUTH_TOKEN
auth_token: ""

# Default task if none provided in /predict request
default_task: "Pick up the object."

# Stub mode: sine-wave actions, no ML dependencies (for testing).
# /health reports stub: true so clients can detect it.
stub: false

# Stub action dimension (pi05 backend). Default 6 (SO-101);
# set 29 for Unitree G1 sim rollouts. Env override: VLA_ACTION_DIM
# action_dim: 29

# ── GR00T N1.7 (model: groot) ────────────────────────────────────
# Connects to an Isaac-GR00T PolicyServer (run_gr00t_server.py) over ZMQ.
groot_host: localhost
groot_port: 5555
# Token for the ZMQ leg — pass the same value as --api-token to
# run_gr00t_server.py. Env override: VLA_GROOT_API_TOKEN
groot_api_token: ""
# Modality keys must match the embodiment config of your fine-tuned
# checkpoint (SO-101 defaults shown).
groot_video_key: front
groot_state_keys:
  single_arm: 5
  gripper: 1
groot_action_keys:
  single_arm: 5
  gripper: 1
groot_timeout_ms: 15000
# Startup ping attempts (2s apart) before giving up — raise this if the
# GPU-side PolicyServer boots slower than vla-server.
groot_ping_retries: 3
